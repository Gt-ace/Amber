# Path to the Amber space directory (the folder containing amber.toml).
# Required at runtime — the server refuses to start without it.
# AMBER_SPACE_PATH=/path/to/your-space

# Canonical, public-facing base URL for this space. Used to build absolute
# URLs in sitemap.xml, robots.txt, og:url, and rel=canonical.
# When unset, sitemap.xml falls back to relative URLs (and logs a warning),
# robots.txt omits the Sitemap line, and og:url / canonical use the page
# path alone. Strip any trailing slash; the loader normalizes it anyway.
PUBLIC_SITE_URL=https://amber.example
